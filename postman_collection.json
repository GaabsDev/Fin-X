                    "response": []
                },
                {
                    "name": "Criar Paciente",
                    "event": [
                        {
                            "listen": "test",
                            "script": {
                                "exec": [
                                    "if (pm.response.code === 201) {",
                                    "    const patient = pm.response.json();",
                                    "    pm.collectionVariables.set('patient_id', patient.id);",
                                    "    pm.test('Paciente criado com sucesso', function () {",
                                    "        pm.expect(patient.id).to.not.be.empty;",
                                    "        pm.expect(patient.name).to.eql('João Silva');",
                                    "    });",
                                    "}"
                                ],
                                "type": "text/javascript"
                            }
                        }
                    ],
                    "request": {
                        "method": "POST",
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"name\": \"João Silva\",\n  \"cpf\": \"12345678901\",\n  \"dateOfBirth\": \"1985-03-15T00:00:00Z\",\n  \"contact\": \"joao@email.com | (11) 99999-9999\"\n}"
                        },
                        "url": {
                            "raw": "{{base_url}}/api/patients",
                            "host": [
                                "{{base_url}}"
                            ],
                            "path": [
                                "api",
                                "patients"
                            ]
                        }
